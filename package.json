{
  "name": "murmur",
  "version": "1.1.0",
  "private": true,
  "description": "Personal broadcaster — your accounts, your machine, forever free.",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:clean": "node scripts/clean.mjs && turbo build",
    "build:ci": "node scripts/clean.mjs && pnpm format:check && pnpm lint && pnpm typecheck && turbo build",
    "clean": "node scripts/clean.mjs",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "dist:mac": "pnpm build:clean && pnpm --filter @murmur/main dist:mac",
    "dist:win": "pnpm build:clean && pnpm --filter @murmur/main dist:win",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.1",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  }
}
